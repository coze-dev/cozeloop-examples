{
  "name": "openclaw-fornax-trace",
  "version": "0.1.0",
  "description": "OpenClaw Plugin for reporting traces to Fornax via OpenTelemetry",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "fornax",
    "tracing",
    "opentelemetry"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@next-ai/fornax-api": "^1.2.1",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.48.0",
    "@opentelemetry/resources": "^1.22.0",
    "@opentelemetry/sdk-trace-base": "^1.22.0",
    "@opentelemetry/semantic-conventions": "^1.22.0"
  }
}
