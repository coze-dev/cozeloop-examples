{
  "name": "@next-ai/fornax-api",
  "version": "1.2.1",
  "description": "Fornax Open API",
  "author": "qihai@bytedance.com",
  "exports": {
    ".": {
      "types": "./dist/typings/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./fornax": {
      "types": "./dist/typings/bam-auto-generated/fornax-api/index.d.ts",
      "import": "./dist/bam-auto-generated/fornax-api/index.mjs",
      "require": "./dist/bam-auto-generated/fornax-api/index.js"
    },
    "./prompt": {
      "types": "./dist/typings/bam-auto-generated/prompt-api/index.d.ts",
      "import": "./dist/bam-auto-generated/prompt-api/index.mjs",
      "require": "./dist/bam-auto-generated/prompt-api/index.js"
    },
    "./knowledge": {
      "types": "./dist/typings/bam-auto-generated/knowledge-api/index.d.ts",
      "import": "./dist/bam-auto-generated/knowledge-api/index.mjs",
      "require": "./dist/bam-auto-generated/knowledge-api/index.js"
    },
    "./evaluation": {
      "types": "./dist/typings/bam-auto-generated/evaluation-api/index.d.ts",
      "import": "./dist/bam-auto-generated/evaluation-api/index.mjs",
      "require": "./dist/bam-auto-generated/evaluation-api/index.js"
    },
    "./evaluation2": {
      "types": "./dist/typings/bam-auto-generated/evaluation2-api/index.d.ts",
      "import": "./dist/bam-auto-generated/evaluation2-api/index.mjs",
      "require": "./dist/bam-auto-generated/evaluation2-api/index.js"
    },
    "./observability": {
      "types": "./dist/typings/bam-auto-generated/observability-api/index.d.ts",
      "import": "./dist/bam-auto-generated/observability-api/index.mjs",
      "require": "./dist/bam-auto-generated/observability-api/index.js"
    },
    "./dataset": {
      "types": "./dist/typings/bam-auto-generated/dataset-api/index.d.ts",
      "import": "./dist/bam-auto-generated/dataset-api/index.mjs",
      "require": "./dist/bam-auto-generated/dataset-api/index.js"
    }
  },
  "types": "./dist/typings/index.d.ts",
  "typesVersions": {
    "*": {
      "fornax": [
        "./dist/typings/bam-auto-generated/fornax-api/index.d.ts"
      ],
      "prompt": [
        "./dist/typings/bam-auto-generated/prompt-api/index.d.ts"
      ],
      "knowledge": [
        "./dist/typings/bam-auto-generated/knowledge-api/index.d.ts"
      ],
      "evaluation": [
        "./dist/typings/bam-auto-generated/evaluation-api/index.d.ts"
      ],
      "evaluation2": [
        "./dist/typings/bam-auto-generated/evaluation2-api/index.d.ts"
      ],
      "observability": [
        "./dist/typings/bam-auto-generated/observability-api/index.d.ts"
      ],
      "dataset": [
        "./dist/typings/bam-auto-generated/dataset-api/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "bam": "bam",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "lint": "eslint ./ --cache",
    "prepublishOnly": "tsup",
    "start": "vitest watch",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "update-bam": "bam clear-cache && bam update",
    "vitest": "vitest"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "create-hmac": "^1.1.7",
    "json-bigint": "~1.0.0"
  },
  "devDependencies": {
    "@byted-arch-fe/bam-code-generator": "^1.16.0",
    "@coze-arch/eslint-config": "workspace:*",
    "@coze-arch/ts-config": "workspace:*",
    "@coze-arch/vitest-config": "workspace:*",
    "@types/create-hmac": "^1.1.3",
    "@types/node": "^18",
    "@vitest/coverage-v8": "~3.0.5",
    "rimraf": "~3.0.2",
    "tsup": "^8.0.1",
    "typescript": "~5.8.2",
    "vitest": "~3.0.5"
  }
}
